# /etc/nginx/sites-available/digitalfuturenh.com
# Static site served from /opt/nh-digital-future-pac
# After symlink + certbot run:
#   sudo ln -s /etc/nginx/sites-available/digitalfuturenh.com /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d digitalfuturenh.com -d www.digitalfuturenh.com
#   sudo systemctl reload nginx

server {
    listen 80;
    server_name digitalfuturenh.com www.digitalfuturenh.com;
    root /opt/nh-digital-future-pac;
    index index.html;

    # Clean URLs
    location / {
        try_files $uri $uri/ $uri.html $uri/index.html =404;
    }

    location /css/   { expires 7d; add_header Cache-Control "public, max-age=604800"; }
    location /js/    { expires 7d; add_header Cache-Control "public, max-age=604800"; }
    location /images/ { expires 30d; add_header Cache-Control "public, max-age=2592000"; }

    location = /robots.txt  { access_log off; }
    location = /favicon.ico { access_log off; log_not_found off; }
    location = /favicon.svg { access_log off; }
    location = /favicon.png { access_log off; }
    location = /sitemap.xml { access_log off; }

    # Email signup endpoint stub - wire up to a Flask app later
    # location /api/ { proxy_pass http://127.0.0.1:5024; ... }

    location ~ /\.(?!well-known) { deny all; }
}
